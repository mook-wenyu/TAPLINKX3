<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <application
        android:name=".SemanticControlApplication"
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.SemanticControl">
        <meta-data
            android:name="com.rayneo.mercury.app"
            android:value="true" />

        <activity
            android:name=".CameraFeasibilityActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name="dev.wenyu.semanticcontrol.feature.semantic.debug.SemanticDebugReceiver"
            android:permission="android.permission.DUMP"
            android:exported="true">
            <intent-filter>
                <action android:name="dev.wenyu.semanticcontrol.debug.ACTION_COMMAND" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="dev.wenyu.semanticcontrol.app.HomepageDebugReceiver"
            android:permission="android.permission.DUMP"
            android:exported="true">
            <intent-filter>
                <action android:name="dev.wenyu.semanticcontrol.debug.ACTION_HOMEPAGE_COMMAND" />
            </intent-filter>
        </receiver>

        <service
            android:name="dev.wenyu.semanticcontrol.feature.semantic.SemanticAccessibilityService"
            android:description="@string/a11y_service_description"
            android:exported="false"
            android:label="@string/a11y_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/semantic_accessibility_service" />
        </service>
    </application>

</manifest>
